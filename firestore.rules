rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'raedelkady@gmail.com',
          'nizarelkady@gmail.com'
        ];
    }

    // Dashboard operators: can view + approve payments + delete spam
    // registrations, but cannot edit categories/theme/competition.
    function isViewer() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'mary.bi.mbi@gmail.com',
          'raedelkady84@gmail.com',
          'rcasper1184@gmail.com'
        ];
    }
    function canReadDashboard() { return isAdmin() || isViewer(); }

    function isValidNewRegistration() {
      let d = request.resource.data;
      return d.firstName is string && d.firstName.size() > 0 && d.firstName.size() < 100
        && d.lastName  is string && d.lastName.size()  > 0 && d.lastName.size()  < 100
        && d.email     is string && d.email.size()     < 200
        && d.phone     is string && d.phone.size()     > 0
        && d.categoryId is string
        && d.whishReference is string
        // payment fields locked on create
        && (d.paymentStatus == 'pending' || d.paymentStatus == 'free')
        && (!('bibNumber' in d.keys()) || d.bibNumber == null)
        && (!('paidAt' in d.keys())    || d.paidAt    == null)
        // consents required
        && d.consents.waiver    == true
        && d.consents.dataUsage == true;
    }

    function registrationOpen(competitionId) {
      // Allow registration when:
      //   - the competition doc doesn't exist yet, OR
      //   - we are inside the [registrationOpens, registrationCloses) window.
      // Either bound being null means "no limit on that side".
      let compPath = /databases/$(database)/documents/competitions/$(competitionId);
      let opens  = get(compPath).data.get('registrationOpens',  null);
      let closes = get(compPath).data.get('registrationCloses', null);
      return !exists(compPath)
          || (
              (opens  == null || request.time >= opens)
           && (closes == null || request.time <  closes)
          );
    }

    // --- Routes ---

    match /competitions/{competitionId} {
      allow read:  if true;
      allow write: if isAdmin();

      // Categories: public read (page needs them), admin write
      match /categories/{categoryId} {
        allow read:  if true;
        allow write: if isAdmin();
      }

      // Theme / form-schema / arbitrary config docs: public read, admin write
      match /config/{configId} {
        allow read:  if true;
        allow write: if isAdmin();
      }

      // Registrations:
      //   - admin + viewer can READ and UPDATE (approve payment, soft-delete)
      //   - only admin can HARD DELETE (from the Backup tab)
      //   - public can CREATE only.
      // Soft-delete = setting deletedAt on the doc; the row is hidden from
      // the main dashboard but kept for admin backup review.
      match /registrations/{regId} {
        allow read:   if canReadDashboard();
        allow create: if isValidNewRegistration() && registrationOpen(competitionId);
        allow update: if canReadDashboard();
        allow delete: if isAdmin();
      }
    }

    // Everything else: deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
